# .env.example
# 실제 값을 채운 뒤 파일명을 .env 로 변경해서 사용하세요.
# .env 파일은 git에 커밋하지 않습니다 (.gitignore에 포함됨).

# FRED (연준 경제지표) API 키
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Threads 원문 요약 / 자연어 전략 해석 / 포트폴리오 AI 코멘트에 사용할 Gemini API 키.
# 발급: https://aistudio.google.com/apikey
# 쉼표로 여러 개 등록하면 하나가 쿼터 소진(429)될 때 자동으로 다음 키로 전환된다
# (core/gemini_client.py). 키가 하나뿐이면 GEMINI_API_KEY만 써도 된다.
GEMINI_API_KEYS=
# GEMINI_API_KEY=

# (선택) SEC EDGAR API 요청 시 User-Agent에 넣을 연락처 정보
# EDGAR는 User-Agent에 이메일 등 식별 정보를 요구함
SEC_EDGAR_USER_AGENT=your_name your_email@example.com

# (선택) SQLite DB 파일 경로를 기본값(data/quant.db)이 아닌 다른 곳으로 바꾸고 싶을 때
# DATABASE_URL=sqlite:///data/quant.db
