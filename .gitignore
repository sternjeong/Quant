# --- Python ---
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# --- 환경변수 ---
.env

# --- DB / 캐시 데이터 (로컬 산출물, 커밋하지 않음) ---
data/*.db
data/*.db-journal
data/cache/*
!data/cache/.gitkeep
!data/.gitkeep
# 거시지표(FRED) 캐시는 예외적으로 커밋한다 - 야간 GitHub Actions가 갱신해두면
# Streamlit Cloud 배포본이 매 방문마다 FRED API를 안 때리고 이 캐시를 바로 읽을 수 있다.
# 개별 종목 가격 parquet 캐시(1000개+, 수십MB)는 계속 불어나므로 커밋 대상에서 제외.
!data/cache/fred_*.csv

# --- Streamlit ---
.streamlit/secrets.toml

# --- OS / 에디터 ---
.DS_Store
.idea/
.vscode/

# --- 테스트 ---
.pytest_cache/
.coverage

# --- 임시 분석/튜닝 스크립트 산출물 (재현 가능, 커밋하지 않음) ---
.tuning_runs/
